# Database
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster>/<db_name>?retryWrites=true&w=majority
# Optional: fail fast when MongoDB is unreachable
MONGODB_SERVER_SELECTION_TIMEOUT_MS=4000
MONGODB_CONNECT_TIMEOUT_MS=4000
MONGODB_SOCKET_TIMEOUT_MS=8000
MONGODB_SRV_LOOKUP_TIMEOUT_MS=1500
MONGODB_CONNECT_RETRIES=1
MONGODB_CONNECT_RETRY_DELAY_MS=750
MONGODB_RETRY_COOLDOWN_MS=10000

# App auth/session
JWT_SECRET=replace-with-a-long-random-secret
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-...

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Optional: enable Clerk during local development
NEXT_PUBLIC_ENABLE_CLERK_IN_DEV=true
# Optional: enrich session with latest DB profile fields on each request
SESSION_ENRICH_FROM_DB=false

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM="ShopNet <onboarding@resend.dev>"

# SMS (Twilio)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Admin
ADMIN_EMAIL=admin@example.com
